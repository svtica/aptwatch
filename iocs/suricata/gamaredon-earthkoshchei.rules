# ---------------------------------------------------------
# EARTH KOSHCHEI RDP Connection Detection on Port 3389
# Generic detection for rogue RDP connections
# ---------------------------------------------------------

alert tcp $HOME_NET any -> $EXTERNAL_NET 3389 (msg:"APTWATCH Earth Koshchei potential rogue RDP connection"; flow:established,to_server; threshold:type both, track by_src, count 3, seconds 60; classtype:policy-violation; sid:2026033269; rev:1; metadata:created_at 2026_03_31, updated_at 2026_03_31, actor Earth_Koshchei, mitre_attack T1219;)

