# ---------------------------------------------------------
# ZEROLOGON (CVE-2020-1472) - Used by Conti for DC compromise
# ---------------------------------------------------------

alert tcp $HOME_NET any -> $HOME_NET 135 (msg:"APTWATCH ZeroLogon CVE-2020-1472 Netlogon exploit attempt"; flow:established,to_server; content:"|00 00|"; depth:2; content:"|00 00 00 00 00 00 00 00|"; distance:6; within:8; threshold:type both, track by_src, count 5, seconds 2; classtype:attempted-admin; sid:2026033018; rev:1; metadata:created_at 2026_03_30, updated_at 2026_03_30, cve CVE-2020-1472, actor Conti, mitre_attack T1068;)
