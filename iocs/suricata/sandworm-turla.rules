# ============================================================================
# SANDWORM BACKORDER KMS BEACON DETECTION (SID 2026033307)
# ============================================================================

alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"APTWATCH Sandworm BACKORDER KMS beacon"; flow:established,to_server; http.user_agent; content:"KMS"; nocase; threshold:type both, track by_src, count 5, seconds 300; classtype:trojan-activity; sid:2026033307; rev:1; metadata:created_at 2026_03_31, actor Sandworm, campaign BACKORDER;)

