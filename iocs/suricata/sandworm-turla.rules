# ============================================================================
# SANDWORM DNS/DOMAIN DETECTION (SID 2026033304 - 2026033306)
# ============================================================================

alert dns $HOME_NET any -> any any (msg:"APTWATCH Sandworm domain hostapp.be"; dns.query; content:"hostapp.be"; nocase; classtype:trojan-activity; sid:2026033304; rev:1; metadata:created_at 2026_03_31, actor Sandworm, mitre_attack T1071.001;)

alert dns $HOME_NET any -> any any (msg:"APTWATCH Sandworm domain esetsmart.com"; dns.query; content:"esetsmart.com"; nocase; classtype:trojan-activity; sid:2026033305; rev:1; metadata:created_at 2026_03_31, actor Sandworm, mitre_attack T1071.001;)

