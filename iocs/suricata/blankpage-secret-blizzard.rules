# =============================================================
# APT Watch - Secret Blizzard / BlankPage Detection Rules
# Date: 2026-03-27
# Source: Microsoft MTAC Activity & Tool Profiles
# Actor: Secret Blizzard (FSB Center 16 / Turla / Unit 71330)
# =============================================================
# BlankPage HTTP listener variant uses /OAB/BOOK/ URI pattern
# on port 443 to mimic Exchange/Outlook Address Book paths.
# The listener accepts only connections matching this prefix.
# =============================================================

# BlankPage HTTP listener C2 - outbound connection to /OAB/BOOK/ pattern
alert tls $HOME_NET any -> $EXTERNAL_NET 443 (msg:"APTWATCH Secret Blizzard BlankPage HTTP listener C2 pattern /OAB/BOOK/"; flow:established,to_server; tls.sni; content:"/OAB/BOOK/"; nocase; reference:url,www.microsoft.com/en-us/security/blog/; classtype:trojan-activity; sid:2026032701; rev:1; metadata:created_at 2026_03_27, updated_at 2026_03_27, actor Secret_Blizzard, malware BlankPage, mitre_attack T1071.001;)

# BlankPage HTTP listener C2 - inbound connection (if monitoring server-side)
alert tls $EXTERNAL_NET any -> $HOME_NET 443 (msg:"APTWATCH Secret Blizzard BlankPage inbound C2 /OAB/BOOK/"; flow:established,to_server; tls.sni; content:"/OAB/BOOK/"; nocase; reference:url,www.microsoft.com/en-us/security/blog/; classtype:trojan-activity; sid:2026032702; rev:1; metadata:created_at 2026_03_27, updated_at 2026_03_27, actor Secret_Blizzard, malware BlankPage, mitre_attack T1071.001;)

# BlankPage HTTP variant - plain HTTP fallback detection
alert http any any -> any any (msg:"APTWATCH Secret Blizzard BlankPage C2 URI /OAB/BOOK/"; flow:established,to_server; http.uri; content:"/OAB/BOOK/"; nocase; reference:url,www.microsoft.com/en-us/security/blog/; classtype:trojan-activity; sid:2026032703; rev:1; metadata:created_at 2026_03_27, updated_at 2026_03_27, actor Secret_Blizzard, malware BlankPage, mitre_attack T1071.001;)

# Note: The Graph API/OneDrive variant communicates via legitimate
# Microsoft infrastructure (graph.microsoft.com, onedrive.live.com)
# and cannot be reliably detected via network rules alone.
# Use endpoint detection (file hashes, DLL side-loading) instead.
